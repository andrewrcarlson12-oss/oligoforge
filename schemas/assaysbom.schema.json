{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oligoforge.local/schemas/assaysbom.schema.json",
  "title": "OligoForge AssaySBOM v1",
  "type": "object",
  "required": ["schema_version", "assaysbom_id", "content_sha256", "portfolio_name", "assays"],
  "properties": {
    "schema_version": {"const": "oligoforge-assaysbom/v1"},
    "assaysbom_id": {"type": "string", "pattern": "^ofsbom_[0-9a-f]{24}$"},
    "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "portfolio_name": {"type": "string"},
    "assays": {
      "type": "array", "minItems": 1, "maxItems": 64,
      "items": {
        "type": "object", "required": ["assay_id", "assay_type", "components"],
        "properties": {
          "assay_id": {"type": "string", "minLength": 1},
          "assay_type": {"type": "string"},
          "components": {
            "type": "array", "minItems": 2,
            "items": {"type": "object", "required": ["component_id", "role", "sequence", "order_sequence"]}
          }
        }
      }
    }
  }
}
